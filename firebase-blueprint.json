{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["superAdmin", "hotelAdmin", "staff"] },
        "hotelId": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "roles": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["email", "role", "hotelId", "status"]
    },
    "Hotel": {
      "title": "Hotel",
      "description": "Hotel property information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "trackingCode": { "type": "string" },
        "subscriptionStatus": { "type": "string", "enum": ["active", "suspended", "expired"] },
        "subscriptionExpiry": { "type": "integer" },
        "plan": { "type": "string" },
        "adminUIDs": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "branding": {
          "type": "object",
          "properties": {
            "logoUrl": { "type": "string" },
            "primaryColor": { "type": "string" },
            "secondaryColor": { "type": "string" },
            "address": { "type": "string" },
            "phone": { "type": "string" },
            "email": { "type": "string" },
            "footerNotes": { "type": "string" }
          }
        }
      },
      "required": ["name", "subscriptionStatus", "subscriptionExpiry", "plan", "adminUIDs"]
    },
    "Room": {
      "title": "Room",
      "description": "Hotel room",
      "type": "object",
      "properties": {
        "roomNumber": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "roomTypeId": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["clean", "dirty", "occupied", "maintenance", "vacant", "out_of_service", "inspected", "out_of_order", "reserved"] },
        "floor": { "type": "string" },
        "building": { "type": "string" },
        "wing": { "type": "string" },
        "capacity": { "type": "integer" },
        "amenities": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "notes": { "type": "string" },
        "assignedTo": { "type": "string" }
      },
      "required": ["roomNumber", "type", "price", "status"]
    },
    "RoomType": {
      "title": "Room Type",
      "description": "Room category and configuration",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "basePrice": { "type": "number" },
        "capacity": { "type": "integer" },
        "capacityAdults": { "type": "integer" },
        "capacityChildren": { "type": "integer" },
        "amenities": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "basePrice", "capacity"]
    },
    "RoomBlocking": {
      "title": "Room Blocking",
      "description": "Room unavailability records",
      "type": "object",
      "properties": {
        "roomId": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "reason": { "type": "string", "enum": ["maintenance", "vip", "event", "temporary", "permanent"] },
        "blockedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["roomId", "startDate", "endDate", "reason"]
    },
    "RateConfiguration": {
      "title": "Rate Configuration",
      "description": "Pricing rules for room types",
      "type": "object",
      "properties": {
        "roomTypeId": { "type": "string" },
        "baseRate": { "type": "number" },
        "weekendRate": { "type": "number" },
        "weekdayRate": { "type": "number" },
        "hourlyRate": { "type": "number" }
      },
      "required": ["roomTypeId", "baseRate"]
    },
    "InventoryConsumptionRule": {
      "title": "Inventory Consumption Rule",
      "description": "Automatic inventory deduction rules",
      "type": "object",
      "properties": {
        "roomTypeId": { "type": "string" },
        "itemId": { "type": "string" },
        "quantity": { "type": "number" },
        "trigger": { "type": "string", "enum": ["check_in", "check_out", "daily_cleaning", "deep_cleaning"] }
      },
      "required": ["itemId", "quantity", "trigger"]
    },
    "Reservation": {
      "title": "Reservation",
      "description": "Guest reservation",
      "type": "object",
      "properties": {
        "guestName": { "type": "string" },
        "roomId": { "type": "string" },
        "checkIn": { "type": "string", "format": "date-time" },
        "checkOut": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["booked", "checked_in", "checked_out", "cancelled"] },
        "createdBy": { "type": "string" },
        "guestId": { "type": "string" },
        "corporateId": { "type": "string" },
        "ledgerEntries": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["guestName", "roomId", "checkIn", "checkOut", "status", "createdBy"]
    },
    "HousekeepingTask": {
      "title": "Housekeeping Task",
      "description": "Room cleaning task",
      "type": "object",
      "properties": {
        "roomId": { "type": "string" },
        "status": { "type": "string", "enum": ["dirty", "cleaning", "clean"] },
        "assignedTo": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["roomId", "status", "updatedAt"]
    },
    "StaffMember": {
      "title": "Staff Member",
      "description": "Hotel staff record",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "modules": { "type": "array", "items": { "type": "string" } },
        "uid": { "type": "string" }
      },
      "required": ["name", "role", "uid"]
    },
    "Module": {
      "title": "Module",
      "description": "System module permissions",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "assignedUIDs": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "assignedUIDs"]
    },
    "HotelActivityLog": {
      "title": "Hotel Activity Log",
      "description": "Activity log at hotel level",
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "user": { "type": "string" },
        "module": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["action", "user", "timestamp"]
    },
    "TrackingCode": {
      "title": "Tracking Code",
      "description": "Subscription tracking codes",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "active": { "type": "boolean" },
        "expiryDate": { "type": "integer" },
        "plan": { "type": "string" },
        "maxHotels": { "type": "integer" },
        "issuedBy": { "type": "string" }
      },
      "required": ["code", "active", "expiryDate", "plan", "issuedBy"]
    },
    "TrackingCodeRequest": {
      "title": "Tracking Code Request",
      "description": "Requests for new tracking codes",
      "type": "object",
      "properties": {
        "hotelName": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["hotelName", "email", "status", "createdAt"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "SaaS subscription details",
      "type": "object",
      "properties": {
        "plan": { "type": "string" },
        "roomLimit": { "type": "integer" },
        "staffLimit": { "type": "integer" },
        "expiresAt": { "type": "integer" },
        "status": { "type": "string", "enum": ["active", "suspended", "expired"] }
      },
      "required": ["plan", "expiresAt", "status"]
    },
    "SystemSettings": {
      "title": "System Settings",
      "description": "Global system configuration",
      "type": "object",
      "properties": {
        "paymentInstructions": { "type": "string" },
        "supportEmail": { "type": "string" }
      }
    },
    "GlobalAuditLog": {
      "title": "Global Audit Log",
      "description": "Critical system actions",
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "actor": { "type": "string" },
        "target": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["action", "actor", "timestamp"]
    },
    "Guest": {
      "title": "Guest",
      "description": "Guest profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "preferences": { "type": "array", "items": { "type": "string" } },
        "ledgerBalance": { "type": "number" },
        "stayHistory": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "email", "phone", "ledgerBalance"]
    },
    "LedgerEntry": {
      "title": "Ledger Entry",
      "description": "Guest financial transaction",
      "type": "object",
      "properties": {
        "guestId": { "type": "string" },
        "hotelId": { "type": "string" },
        "type": { "type": "string", "enum": ["debit", "credit"] },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "referenceId": { "type": "string" },
        "category": { "type": "string", "enum": ["room", "restaurant", "service", "payment"] },
        "postedBy": { "type": "string" }
      },
      "required": ["guestId", "hotelId", "type", "amount", "description", "timestamp", "category", "postedBy"]
    },
    "CorporateAccount": {
      "title": "Corporate Account",
      "description": "Company account for bookings",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "contactPerson": { "type": "string" },
        "taxId": { "type": "string" },
        "creditLimit": { "type": "number" },
        "currentBalance": { "type": "number" },
        "billingCycle": { "type": "string", "enum": ["weekly", "monthly", "quarterly"] },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "phone", "creditLimit", "currentBalance", "billingCycle", "status", "createdAt"]
    },
    "CorporateRate": {
      "title": "Corporate Rate",
      "description": "Negotiated room rate for a corporate account",
      "type": "object",
      "properties": {
        "corporateId": { "type": "string" },
        "roomType": { "type": "string" },
        "rate": { "type": "number" },
        "currency": { "type": "string", "enum": ["NGN", "USD"] },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"] },
        "discountValue": { "type": "number" },
        "conditions": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["corporateId", "roomType", "rate", "currency", "startDate", "endDate", "status", "createdAt"]
    },
    "Registration": {
      "title": "Registration Record",
      "description": "A record of a new hotel registration attempt",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "hotelName": { "type": "string" },
        "trackingCode": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] }
      },
      "required": ["uid", "email", "hotelName", "trackingCode", "timestamp"]
    },
    "FinanceRecord": {
      "title": "Finance Record",
      "description": "Hotel financial transaction",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "amount", "category", "date", "timestamp"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "Item master record",
      "type": "object",
      "properties": {
        "sku": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "unit": { "type": "string" },
        "type": { "type": "string", "enum": ["consumable", "non-consumable", "perishable"] },
        "quantity": { "type": "number" },
        "minThreshold": { "type": "number" },
        "price": { "type": "number" },
        "valuationMethod": { "type": "string", "enum": ["FIFO", "LIFO", "WAC"] },
        "status": { "type": "string", "enum": ["active", "discontinued", "out_of_stock"] }
      },
      "required": ["sku", "name", "category", "unit", "type", "quantity", "minThreshold", "price", "valuationMethod", "status"]
    },
    "InventoryVendor": {
      "title": "Inventory Vendor",
      "description": "Supplier profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      },
      "required": ["name", "status"]
    },
    "PurchaseOrder": {
      "title": "Purchase Order",
      "description": "Procurement order",
      "type": "object",
      "properties": {
        "poNumber": { "type": "string" },
        "supplierId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "received", "partial", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "partial", "paid"] }
      },
      "required": ["poNumber", "supplierId", "totalAmount", "status", "paymentStatus"]
    },
    "InventoryTransaction": {
      "title": "Inventory Transaction",
      "description": "Stock movement record",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["stock_in", "stock_out", "transfer", "adjustment", "consumption", "return"] },
        "itemId": { "type": "string" },
        "quantity": { "type": "number" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "itemId", "quantity", "userId", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/hotels/{hotelId}": {
      "schema": "Hotel",
      "description": "Hotel properties"
    },
    "/hotels/{hotelId}/inventory/{itemId}": {
      "schema": "InventoryItem",
      "description": "Inventory items"
    },
    "/hotels/{hotelId}/inventory_vendors/{vendorId}": {
      "schema": "InventoryVendor",
      "description": "Inventory vendors"
    },
    "/hotels/{hotelId}/purchase_orders/{poId}": {
      "schema": "PurchaseOrder",
      "description": "Purchase orders"
    },
    "/hotels/{hotelId}/inventory_transactions/{txId}": {
      "schema": "InventoryTransaction",
      "description": "Inventory transactions"
    },
    "/hotels/{hotelId}/rooms/{roomId}": {
      "schema": "Room",
      "description": "Hotel rooms"
    },
    "/hotels/{hotelId}/room_types/{typeId}": {
      "schema": "RoomType",
      "description": "Room types"
    },
    "/hotels/{hotelId}/room_blockings/{blockingId}": {
      "schema": "RoomBlocking",
      "description": "Room blockings"
    },
    "/hotels/{hotelId}/rate_configurations/{rateId}": {
      "schema": "RateConfiguration",
      "description": "Rate configurations"
    },
    "/hotels/{hotelId}/inventory_consumption_rules/{ruleId}": {
      "schema": "InventoryConsumptionRule",
      "description": "Inventory consumption rules"
    },
    "/hotels/{hotelId}/reservations/{resId}": {
      "schema": "Reservation",
      "description": "Hotel reservations"
    },
    "/hotels/{hotelId}/housekeeping/{taskId}": {
      "schema": "HousekeepingTask",
      "description": "Housekeeping tasks"
    },
    "/hotels/{hotelId}/staff/{staffId}": {
      "schema": "StaffMember",
      "description": "Hotel staff records"
    },
    "/hotels/{hotelId}/modules/{moduleId}": {
      "schema": "Module",
      "description": "Module permissions"
    },
    "/hotels/{hotelId}/activityLogs/{logId}": {
      "schema": "HotelActivityLog",
      "description": "Hotel activity logs"
    },
    "/hotels/{hotelId}/finance/{recordId}": {
      "schema": "FinanceRecord",
      "description": "Hotel financial records"
    },
    "/hotels/{hotelId}/guests/{guestId}": {
      "schema": "Guest",
      "description": "Guest profiles"
    },
    "/hotels/{hotelId}/ledger/{entryId}": {
      "schema": "LedgerEntry",
      "description": "Guest ledger entries"
    },
    "/hotels/{hotelId}/corporate_accounts/{accountId}": {
      "schema": "CorporateAccount",
      "description": "Corporate accounts"
    },
    "/hotels/{hotelId}/corporate_accounts/{accountId}/rates/{rateId}": {
      "schema": "CorporateRate",
      "description": "Negotiated rates for a corporate account"
    },
    "/trackingCodes/{code}": {
      "schema": "TrackingCode",
      "description": "Subscription tracking codes"
    },
    "/trackingCodeRequests/{requestId}": {
      "schema": "TrackingCodeRequest",
      "description": "Requests for tracking codes"
    },
    "/subscriptions/{hotelId}": {
      "schema": "Subscription",
      "description": "SaaS subscriptions"
    },
    "/system/settings": {
      "schema": "SystemSettings",
      "description": "Global system settings"
    },
    "/auditLogs/{logId}": {
      "schema": "GlobalAuditLog",
      "description": "Global audit logs"
    },
    "/registration/{regId}": {
      "schema": "Registration",
      "description": "Hotel registration records"
    }
  }
}
