{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["superAdmin", "hotelAdmin", "staff"] },
        "hotelId": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      },
      "required": ["email", "role", "hotelId", "status"]
    },
    "Hotel": {
      "title": "Hotel",
      "description": "Hotel property information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "trackingCode": { "type": "string" },
        "subscriptionStatus": { "type": "string", "enum": ["active", "suspended", "expired"] },
        "subscriptionExpiry": { "type": "integer" },
        "plan": { "type": "string" },
        "adminUIDs": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "subscriptionStatus", "subscriptionExpiry", "plan", "adminUIDs"]
    },
    "Room": {
      "title": "Room",
      "description": "Hotel room",
      "type": "object",
      "properties": {
        "roomNumber": { "type": "string" },
        "type": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["available", "occupied", "dirty", "maintenance"] },
        "floor": { "type": "integer" }
      },
      "required": ["roomNumber", "type", "price", "status"]
    },
    "Reservation": {
      "title": "Reservation",
      "description": "Guest reservation",
      "type": "object",
      "properties": {
        "guestName": { "type": "string" },
        "roomId": { "type": "string" },
        "checkIn": { "type": "string", "format": "date-time" },
        "checkOut": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["booked", "checked_in", "checked_out", "cancelled"] },
        "createdBy": { "type": "string" }
      },
      "required": ["guestName", "roomId", "checkIn", "checkOut", "status", "createdBy"]
    },
    "HousekeepingTask": {
      "title": "Housekeeping Task",
      "description": "Room cleaning task",
      "type": "object",
      "properties": {
        "roomId": { "type": "string" },
        "status": { "type": "string", "enum": ["dirty", "cleaning", "clean"] },
        "assignedTo": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["roomId", "status", "updatedAt"]
    },
    "StaffMember": {
      "title": "Staff Member",
      "description": "Hotel staff record",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "modules": { "type": "array", "items": { "type": "string" } },
        "uid": { "type": "string" }
      },
      "required": ["name", "role", "uid"]
    },
    "Module": {
      "title": "Module",
      "description": "System module permissions",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "assignedUIDs": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "assignedUIDs"]
    },
    "HotelActivityLog": {
      "title": "Hotel Activity Log",
      "description": "Activity log at hotel level",
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "user": { "type": "string" },
        "module": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["action", "user", "timestamp"]
    },
    "TrackingCode": {
      "title": "Tracking Code",
      "description": "Subscription tracking codes",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "active": { "type": "boolean" },
        "expiryDate": { "type": "integer" },
        "plan": { "type": "string" },
        "maxHotels": { "type": "integer" },
        "issuedBy": { "type": "string" }
      },
      "required": ["code", "active", "expiryDate", "plan", "issuedBy"]
    },
    "TrackingCodeRequest": {
      "title": "Tracking Code Request",
      "description": "Requests for new tracking codes",
      "type": "object",
      "properties": {
        "hotelName": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["hotelName", "email", "status", "createdAt"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "SaaS subscription details",
      "type": "object",
      "properties": {
        "plan": { "type": "string" },
        "roomLimit": { "type": "integer" },
        "staffLimit": { "type": "integer" },
        "expiresAt": { "type": "integer" },
        "status": { "type": "string", "enum": ["active", "suspended", "expired"] }
      },
      "required": ["plan", "expiresAt", "status"]
    },
    "SystemSettings": {
      "title": "System Settings",
      "description": "Global system configuration",
      "type": "object",
      "properties": {
        "paymentInstructions": { "type": "string" },
        "supportEmail": { "type": "string" }
      }
    },
    "GlobalAuditLog": {
      "title": "Global Audit Log",
      "description": "Critical system actions",
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "actor": { "type": "string" },
        "target": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["action", "actor", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/hotels/{hotelId}": {
      "schema": "Hotel",
      "description": "Hotel properties"
    },
    "/hotels/{hotelId}/rooms/{roomId}": {
      "schema": "Room",
      "description": "Hotel rooms"
    },
    "/hotels/{hotelId}/reservations/{resId}": {
      "schema": "Reservation",
      "description": "Hotel reservations"
    },
    "/hotels/{hotelId}/housekeeping/{taskId}": {
      "schema": "HousekeepingTask",
      "description": "Housekeeping tasks"
    },
    "/hotels/{hotelId}/staff/{staffId}": {
      "schema": "StaffMember",
      "description": "Hotel staff records"
    },
    "/hotels/{hotelId}/modules/{moduleId}": {
      "schema": "Module",
      "description": "Module permissions"
    },
    "/hotels/{hotelId}/activityLogs/{logId}": {
      "schema": "HotelActivityLog",
      "description": "Hotel activity logs"
    },
    "/trackingCodes/{code}": {
      "schema": "TrackingCode",
      "description": "Subscription tracking codes"
    },
    "/trackingCodeRequests/{requestId}": {
      "schema": "TrackingCodeRequest",
      "description": "Requests for tracking codes"
    },
    "/subscriptions/{hotelId}": {
      "schema": "Subscription",
      "description": "SaaS subscriptions"
    },
    "/system/settings": {
      "schema": "SystemSettings",
      "description": "Global system settings"
    },
    "/auditLogs/{logId}": {
      "schema": "GlobalAuditLog",
      "description": "Global audit logs"
    }
  }
}
