rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is the hardcoded bootstrap admin (case-insensitive)
    function isBootstrapAdmin() {
      return isAuthenticated() && 
             request.auth.token.email != null &&
             request.auth.token.email.lower() == "smartwavetechcompany@gmail.com";
    }

    function isSuperAdmin() {
      return isBootstrapAdmin() || (isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "superAdmin");
    }

    // Get user data from the users collection
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Check if user has a specific role in their profile
    function hasRole(role) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData().role == role;
    }

    // ===============================================================
    // Global Super Admin Access - MUST BE FIRST
    // ===============================================================
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    function isHotelAdmin() {
      return hasRole("hotelAdmin");
    }

    function isStaff() {
      return hasRole("staff");
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // 🔓 Allow public hotel requests
    match /trackingCodeRequests/{requestId} {
      allow create: if true;
      allow read, write: if isSuperAdmin();
    }

    // 🔓 Public system settings
    match /system/settings {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Users collection - CRITICAL SECURITY
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
      
      // Only allow creation if it's the user's own profile
      // Role MUST be 'hotelAdmin' or 'staff' unless they are already a SuperAdmin
      allow create: if isAuthenticated() && request.auth.uid == userId && (
        (request.resource.data.role in ['hotelAdmin', 'staff']) || 
        isSuperAdmin()
      );

      // Only SuperAdmin can change roles. Users can only update their own non-role fields.
      allow update: if isAuthenticated() && (
        isSuperAdmin() || 
        (request.auth.uid == userId && request.resource.data.role == resource.data.role)
      );

      allow delete: if isSuperAdmin();
    }

    // Hotels collection
    match /hotels/{hotelId} {
      allow read, write: if isSuperAdmin();
      
      allow read: if isAuthenticated() && (
        (isHotelAdmin() && request.auth.uid in resource.data.adminUIDs) ||
        (isStaff() && getUserData().hotelId == hotelId)
      );

      // Only admins can update hotel details
      allow update: if isHotelAdmin() && request.auth.uid in resource.data.adminUIDs;

      // Subcollections (rooms, reservations, etc.)
      match /{subCollection}/{docId} {
        allow read, write: if isSuperAdmin() || (
          isAuthenticated() && 
          getUserData().hotelId == hotelId && 
          (isHotelAdmin() || isStaff())
        );
      }
    }

    // Tracking Codes
    match /trackingCodes/{codeId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Activity Logs
    match /activityLogs/{logId} {
      allow create: if isAuthenticated();
      allow read, write: if isSuperAdmin();
    }
  }
}
