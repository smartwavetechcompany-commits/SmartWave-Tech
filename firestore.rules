rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "smartwavetechcompany@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "superAdmin")
      );
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isHotelAdmin(hotelId) {
      let userData = getUserData();
      return isAuthenticated() && 
             userData.role == "hotelAdmin" && 
             userData.hotelId == hotelId;
    }

    function isStaff(hotelId) {
      let userData = getUserData();
      return isAuthenticated() && 
             userData.role == "staff" && 
             userData.hotelId == hotelId;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if staff has access to a specific module
    function hasModuleAccess(hotelId, moduleName) {
      return isStaff(hotelId) && 
             exists(/databases/$(database)/documents/hotels/$(hotelId)/modules/$(moduleName)) &&
             request.auth.uid in get(/databases/$(database)/documents/hotels/$(hotelId)/modules/$(moduleName)).data.assignedUIDs;
    }

    // ===============================================================
    // Global Rules
    // ===============================================================

    // Super Admin can do anything
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // ===============================================================
    // Root Collections
    // ===============================================================

    // Users
    match /users/{uid} {
      allow read: if isOwner(uid) || isSuperAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) && 
                    (request.resource.data.role == resource.data.role || isSuperAdmin());
    }

    // Hotels
    match /hotels/{hotelId} {
      allow read: if isSuperAdmin() || isHotelAdmin(hotelId) || isStaff(hotelId);
      allow write: if isSuperAdmin(); // Only SuperAdmin creates/deletes hotels

      // Hotel Subcollections
      match /rooms/{roomId} {
        allow read: if isSuperAdmin() || isHotelAdmin(hotelId) || hasModuleAccess(hotelId, "rooms");
        allow write: if isSuperAdmin() || isHotelAdmin(hotelId);
      }

      match /reservations/{resId} {
        allow read: if isSuperAdmin() || isHotelAdmin(hotelId) || hasModuleAccess(hotelId, "reservations");
        allow write: if isSuperAdmin() || isHotelAdmin(hotelId) || hasModuleAccess(hotelId, "reservations");
      }

      match /housekeeping/{taskId} {
        allow read: if isSuperAdmin() || isHotelAdmin(hotelId) || hasModuleAccess(hotelId, "housekeeping");
        allow write: if isSuperAdmin() || isHotelAdmin(hotelId) || hasModuleAccess(hotelId, "housekeeping");
      }

      match /staff/{staffId} {
        allow read, write: if isSuperAdmin() || isHotelAdmin(hotelId);
      }

      match /modules/{moduleId} {
        allow read: if isSuperAdmin() || isHotelAdmin(hotelId) || isStaff(hotelId);
        allow write: if isSuperAdmin() || isHotelAdmin(hotelId);
      }

      match /activityLogs/{logId} {
        allow read: if isSuperAdmin() || isHotelAdmin(hotelId);
        allow create: if isAuthenticated() && getUserData().hotelId == hotelId;
      }

      match /inventory/{itemId} {
        allow read: if isSuperAdmin() || isHotelAdmin(hotelId) || hasModuleAccess(hotelId, "inventory");
        allow write: if isSuperAdmin() || isHotelAdmin(hotelId) || hasModuleAccess(hotelId, "inventory");
      }

      match /payments/{paymentId} {
        allow read, write: if isSuperAdmin() || isHotelAdmin(hotelId);
      }

      match /reports/{reportId} {
        allow read: if isSuperAdmin() || isHotelAdmin(hotelId);
        allow write: if isSuperAdmin() || isHotelAdmin(hotelId);
      }
    }

    // Tracking Codes
    match /trackingCodes/{code} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Tracking Code Requests
    match /trackingCodeRequests/{requestId} {
      allow create: if true; // Public
      allow read, write: if isSuperAdmin();
    }

    // Subscriptions
    match /subscriptions/{hotelId} {
      allow read: if isSuperAdmin() || isHotelAdmin(hotelId);
      allow write: if isSuperAdmin();
    }

    // System Settings
    match /system/settings {
      allow read: if true; // Public
      allow write: if isSuperAdmin();
    }

    // Global Audit Logs
    match /auditLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAuthenticated();
    }
  }
}
