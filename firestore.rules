rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //////////////////////////////
    // AUTH HELPERS
    //////////////////////////////

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function userExists() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.uid == "ighGTXpOuehSqh1pTwSXLPz0Akk1" ||
        (request.auth.token.email != null && request.auth.token.email.lower() == "smartwavetechcompany@gmail.com")
      );
    }

    function isAdmin() {
      return isAuthenticated() && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "hotelAdmin" ||
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "manager") ||
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles != null && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['manager', 'corporate']))))
      );
    }

    function isHotelAdmin() {
      let data = getUserData();
      return data != null && data.role == "hotelAdmin";
    }

    function hasStaffManagementPermission() {
      let data = getUserData();
      return data != null && (
        isSuperAdmin() ||
        data.role == "hotelAdmin" ||
        (data.permissions != null && data.permissions.hasAny(['manage_staff', 'manage_roles'])) ||
        (data.roles != null && data.roles.hasAny(['manager', 'admin']))
      );
    }

    function isStaff() {
      let data = getUserData();
      return data != null && data.role == "staff";
    }

    function getHotelId() {
      let data = getUserData();
      return data != null ? data.hotelId : null;
    }

    function sameHotel(hotelId) {
      return getHotelId() == hotelId;
    }

    function isStaffOf(hotelId) {
      let data = getUserData();
      return data != null && data.hotelId == hotelId && data.role != "guest" && data.role != "corporate";
    }

    function subscriptionActive(hotelId) {
      let path = /databases/$(database)/documents/hotels/$(hotelId);
      return exists(path) && get(path).data.subscriptionStatus == "active";
    }

    //////////////////////////////
    // TRACKING CODES
    //////////////////////////////

    match /trackingCodes/{codeId} {

      // Full control for superAdmin
      allow read, write: if isSuperAdmin();

      // Authenticated users can fetch a single code for validation
      allow get: if isAuthenticated();

      // Prevent listing all codes for regular users
      allow list: if isSuperAdmin();

      // One-time usage enforcement
      allow update: if isAuthenticated() &&
        resource.data.status == 'active' &&
        request.resource.data.status == 'used' &&
        request.resource.data.usedByHotel != null &&
        // Robust expiry check: handle both null and timestamp comparisons
        (resource.data.expiryDate == null || timestamp(resource.data.expiryDate) >= request.time) &&
        // Ensure critical fields don't change
        request.resource.data.code == resource.data.code &&
        request.resource.data.plan == resource.data.plan;
    }

    //////////////////////////////
    // USERS
    //////////////////////////////

    match /users/{userId} {
      // Primary access: Self, SuperAdmin, anyone in the same hotel, or by email matching the authenticated token
      allow read, list: if (isAuthenticated() && (
                            request.auth.uid == userId || 
                            isSuperAdmin() || 
                            (resource != null && resource.data.hotelId == getHotelId()) ||
                            (resource != null && (resource.data.email == request.auth.token.email || resource.data.email.lower() == request.auth.token.email.lower()))
                          )) ||
                          (request.auth == null && resource != null && resource.data.initialPassword != null);
      
      // SuperAdmin has full control
      allow write: if isSuperAdmin();

      allow create: if isAuthenticated() && (
                      (request.auth.uid == userId && request.resource.data.role != "superAdmin") ||
                      (isAdmin() && request.resource.data.hotelId == getHotelId() && hasStaffManagementPermission() && request.resource.data.role != "superAdmin")
                    );

      allow update: if isAuthenticated() && (
                      (request.auth.uid == userId && 
                       request.resource.data.role == resource.data.role &&
                       request.resource.data.hotelId == resource.data.hotelId) ||
                      (isAdmin() && resource != null && resource.data.hotelId == getHotelId() &&
                       hasStaffManagementPermission() &&
                       request.resource.data.hotelId == getHotelId() &&
                       (request.auth.uid != userId || (
                         request.resource.data.role == resource.data.role &&
                         request.resource.data.hotelId == resource.data.hotelId
                       )) &&
                       request.resource.data.role != "superAdmin")
                    );

      allow delete: if isAuthenticated() && (
                      isSuperAdmin() ||
                      (isHotelAdmin() && resource != null && resource.data.hotelId == getHotelId() && request.auth.uid != userId)
                    );
    }

    //////////////////////////////
    // HOTELS (Multi-Tenant Root)
    //////////////////////////////

    match /hotels/{hotelId} {
      // Allow creation during registration
      allow create: if isAuthenticated();
      
      // Tenant Isolation
      allow read: if isSuperAdmin() || sameHotel(hotelId);
      allow update: if isSuperAdmin() || (sameHotel(hotelId) && (isHotelAdmin() || isAdmin()));
      allow delete: if isSuperAdmin();

      // Corporate Accounts
      match /corporate_accounts/{accountId} {
        allow read: if isSuperAdmin() || isStaffOf(hotelId);
        allow create, update: if isSuperAdmin() || (isAdmin() && sameHotel(hotelId) && subscriptionActive(hotelId));
        allow delete: if isSuperAdmin() || (sameHotel(hotelId) && isHotelAdmin());

        match /rates/{rateId} {
          allow read: if isSuperAdmin() || isStaffOf(hotelId);
          allow create, update: if isSuperAdmin() || (isAdmin() && sameHotel(hotelId) && subscriptionActive(hotelId));
          allow delete: if isSuperAdmin() || (sameHotel(hotelId) && isHotelAdmin());
        }
      }

      // Ledger entries are immutable and append-only audit logs.
      match /ledger/{entryId} {
        allow read: if isSuperAdmin() || isStaffOf(hotelId);
        allow create: if isSuperAdmin() || (
          isStaffOf(hotelId) && subscriptionActive(hotelId) &&
          request.resource.data.amount != null &&
          request.resource.data.amount >= 0 &&
          request.resource.data.type in ['debit', 'credit'] &&
          request.resource.data.category is string &&
          request.resource.data.timestamp != null
        );
        allow update: if isSuperAdmin(); // Immutable ledger!
        allow delete: if isSuperAdmin(); // Immutable ledger!
      }

      // Recursive subcollections (Rooms, Reservations, Housekeeping, Staff, etc.)
      match /{allSubcollections=**} {
        allow read: if isSuperAdmin() || isStaffOf(hotelId);
        allow create, update: if isSuperAdmin() || (
          isStaffOf(hotelId) && (
            subscriptionActive(hotelId) || 
            allSubcollections[0] == 'auditLogs' || 
            allSubcollections[0] == 'activityLogs'
          )
        );
        allow delete: if isSuperAdmin() || (
          sameHotel(hotelId) && isHotelAdmin()
        );
      }
    }

    //////////////////////////////
    // SYSTEM SETTINGS & LOGS
    //////////////////////////////

    match /system/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /systemLogs/{allPaths=**} {
      allow read: if isSuperAdmin();
      allow create: if isAuthenticated();
    }

    match /activityLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAuthenticated();
    }

    // Collection Group rule for activityLogs
    match /{path=**}/activityLogs/{logId} {
      allow read, list: if isSuperAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAuthenticated();
    }

    match /GlobalAuditLog/{logId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && isAdmin() && resource.data.hotelId == getHotelId());
      allow create: if isAuthenticated();
    }

    match /registration/{docId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isSuperAdmin());
    }

    match /trackingCodeRequests/{requestId} {
      allow read, write: if isSuperAdmin();
      allow create: if isAuthenticated();
    }
  }
}
