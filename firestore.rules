rules_version = '2';
service cloud.firestore {
match /databases/{database}/documents {

//////////////////////////////
// AUTH HELPERS
//////////////////////////////

function isAuthenticated() {
  return request.auth != null;
}

function userDoc() {
  return get(/databases/$(database)/documents/users/$(request.auth.uid));
}

function userExists() {
  return isAuthenticated() &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid));
}

function userRole() {
  return userExists() ? userDoc().data.role : null;
}

function userHotel() {
  return userExists() ? userDoc().data.hotelId : null;
}

function isSuperAdmin() {
  return isAuthenticated() && (
    userRole() == "superAdmin" ||
    request.auth.token.email == "smartwavetechcompany@gmail.com"
  );
}

function isHotelAdmin() {
  return userRole() == "hotelAdmin";
}

function isStaff() {
  return userRole() == "staff";
}

//////////////////////////////
// SUBSCRIPTION CONTROL
//////////////////////////////

function subscriptionActive(hotelId) {
  return exists(/databases/$(database)/documents/hotels/$(hotelId)) &&
         get(/databases/$(database)/documents/hotels/$(hotelId)).data.subscriptionStatus == "active";
}

//////////////////////////////
// TENANT ISOLATION
//////////////////////////////

function sameHotel(hotelId) {
  return userHotel() == hotelId;
}

//////////////////////////////
// TRACKING CODE REQUESTS
//////////////////////////////

match /trackingCodeRequests/{requestId} {
  allow create: if true;
  allow read, update, delete: if isSuperAdmin();
}

//////////////////////////////
// TRACKING CODES
//////////////////////////////

match /trackingCodes/{codeId} {
  allow read: if isSuperAdmin() || isAuthenticated(); // Allow authenticated users to verify code during registration
  allow create, update, delete: if isSuperAdmin();
}

//////////////////////////////
// SYSTEM SETTINGS
//////////////////////////////

match /system/settings {
  allow read: if true;
  allow write: if isSuperAdmin();
}

//////////////////////////////
// USERS
//////////////////////////////

match /users/{userId} {
  allow create: if request.auth.uid == userId;
  allow read: if request.auth.uid == userId || isSuperAdmin();
  allow update: if request.auth.uid == userId || isSuperAdmin();
  allow delete: if isSuperAdmin();
}

//////////////////////////////
// HOTELS
//////////////////////////////

match /hotels/{hotelId} {
  allow create: if isAuthenticated(); // Registration logic handles validation
  allow read: if isSuperAdmin() || sameHotel(hotelId);
  allow update: if isSuperAdmin() || (sameHotel(hotelId) && isHotelAdmin());
  allow delete: if isSuperAdmin();

  //////////////////////////////
  // ROOMS
  //////////////////////////////
  match /rooms/{roomId} {
    allow read: if isSuperAdmin() || sameHotel(hotelId);
    allow create: if isSuperAdmin() || (sameHotel(hotelId) && isHotelAdmin() && subscriptionActive(hotelId));
    allow update, delete: if isSuperAdmin() || (sameHotel(hotelId) && isHotelAdmin());
  }

  //////////////////////////////
  // RESERVATIONS
  //////////////////////////////
  match /reservations/{reservationId} {
    allow read: if isSuperAdmin() || sameHotel(hotelId);
    allow create, update: if isSuperAdmin() || (sameHotel(hotelId) && subscriptionActive(hotelId));
    allow delete: if isSuperAdmin() || (sameHotel(hotelId) && isHotelAdmin());
  }

  //////////////////////////////
  // HOUSEKEEPING
  //////////////////////////////
  match /housekeeping/{taskId} {
    allow read: if isSuperAdmin() || sameHotel(hotelId);
    allow create, update: if isSuperAdmin() || (sameHotel(hotelId) && subscriptionActive(hotelId));
    allow delete: if isSuperAdmin() || (sameHotel(hotelId) && isHotelAdmin());
  }

  //////////////////////////////
  // STAFF
  //////////////////////////////
  match /staff/{staffId} {
    allow read: if isSuperAdmin() || sameHotel(hotelId);
    allow create, update, delete: if isSuperAdmin() || (sameHotel(hotelId) && isHotelAdmin());
  }

  //////////////////////////////
  // MODULE PERMISSIONS
  //////////////////////////////
  match /modules/{moduleId} {
    allow read: if isSuperAdmin() || sameHotel(hotelId);
    allow write: if isSuperAdmin() || (sameHotel(hotelId) && isHotelAdmin()) || (isStaff() && request.auth.uid in request.resource.data.assignedUIDs);
  }

  //////////////////////////////
  // HOTEL ACTIVITY LOGS
  //////////////////////////////
  match /activityLogs/{logId} {
    allow create: if isAuthenticated() && sameHotel(hotelId);
    allow read: if isSuperAdmin() || (sameHotel(hotelId) && isHotelAdmin());
  }
  
  //////////////////////////////
  // FINANCE
  //////////////////////////////
  match /finance/{recordId} {
    allow read: if isSuperAdmin() || sameHotel(hotelId);
    allow write: if isSuperAdmin() || (sameHotel(hotelId) && isHotelAdmin());
  }
}

//////////////////////////////
// SUBSCRIPTIONS
//////////////////////////////

match /subscriptions/{hotelId} {
  allow read, write: if isSuperAdmin();
}

//////////////////////////////
// GLOBAL AUDIT LOGS
//////////////////////////////

match /auditLogs/{logId} {
  allow read: if isSuperAdmin();
  allow create: if isAuthenticated();
}

}
}
